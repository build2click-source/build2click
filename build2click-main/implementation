// --- Main App Layout ---
export default function App() {
    const [currentPage, setCurrentPage] = useState('home');
    const [scrolled, setScrolled] = useState(false);

    useEffect(() => {
        const handleScroll = () => {
            setScrolled(window.scrollY > 20);
        };
        window.addEventListener('scroll', handleScroll);
        return () => window.removeEventListener('scroll', handleScroll);
    }, []);

    // Scroll to top on page change
    useEffect(() => {
        window.scrollTo(0, 0);
    }, [currentPage]);

    const navLinks = [
        { id: 'home', label: 'Home' },
        { id: 'services', label: 'Services' },
        { id: 'about', label: 'About Us' },
        { id: 'contact', label: 'Contact' },
        { id: 'card', label: 'vCard' } // Hidden in main nav usually, but added here for testing
    ];

    const renderPage = () => {
        switch (currentPage) {
            case 'home': return <HomePage navigate={setCurrentPage} />;
            case 'about': return <AboutPage />;
            case 'services': return <ServicesPage />;
            case 'contact': return <ContactPage />;
            case 'card': return <DigitalCardPage />;
            default: return <HomePage navigate={setCurrentPage} />;
        }
    };

    return (
        <div className="min-h-screen flex flex-col">
            <GlobalStyles />

            {/* Navigation */}
            {currentPage !== 'card' && (
                <nav className={`fixed top-0 w-full z-50 transition-all duration-300 ${scrolled ? 'bg-white/80 backdrop-blur-md shadow-sm py-4' : 'bg-transparent py-6'}`}>
                    <div className="max-w-7xl mx-auto px-6 lg:px-8 flex justify-between items-center">
                        {/* Logo */}
                        <div
                            className="flex items-center cursor-pointer group"
                            onClick={() => setCurrentPage('home')}
                        >
                            <div className="bg-[#C8A153] text-white p-2 rounded-lg mr-3 shadow-md group-hover:scale-105 transition-transform">
                                <Zap size={20} fill="currentColor" />
                            </div>
                            <span className="font-bold text-xl tracking-tight heading-font">BUILD2CLICK</span>
                        </div>

                        {/* Desktop Links */}
                        <div className="hidden md:flex items-center space-x-8">
                            {navLinks.slice(0, 4).map(link => (
                                <button
                                    key={link.id}
                                    onClick={() => setCurrentPage(link.id)}
                                    className={`text-sm font-bold uppercase tracking-wider transition-colors ${currentPage === link.id ? 'text-[#C8A153]' : 'text-[#1C1C1C] hover:text-[#C8A153]'}`}
                                >
                                    {link.label}
                                </button>
                            ))}
                        </div>

                        {/* CTA */}
                        <div className="hidden md:block">
                            <Button onClick={() => setCurrentPage('contact')} variant="secondary" className="px-6 py-2.5 text-sm">Start Project</Button>
                        </div>
                    </div>
                </nav>
            )}

            {/* Main Content Area */}
            <main className="flex-grow">
                {renderPage()}
            </main>

            {/* Footer */}
            {currentPage !== 'card' && (
                <footer className="bg-white border-t border-gray-100 py-6">
                    <div className="max-w-7xl mx-auto px-6 lg:px-8 grid md:grid-cols-4 gap-6">
                        <div className="md:col-span-2">
                            <div className="flex items-center mb-3">
                                <div className="bg-[#C8A153] text-white p-1.5 rounded-lg mr-3">
                                    <Zap size={18} fill="currentColor" />
                                </div>
                                <span className="font-bold text-lg tracking-tight heading-font">BUILD2CLICK</span>
                            </div>
                            <p className="text-[#6B7280] max-w-md text-sm">
                                Elite digital engineering for ambitious brands. We design, we develop, we convert.
                            </p>
                        </div>

                        <div>
                            <h4 className="font-bold text-xs uppercase tracking-widest mb-3 text-[#1C1C1C]">Navigation</h4>
                            <ul className="space-y-1.5">
                                {navLinks.slice(0, 4).map(link => (
                                    <li key={link.id}>
                                        <button onClick={() => setCurrentPage(link.id)} className="text-[#6B7280] hover:text-[#C8A153] transition-colors text-sm">{link.label}</button>
                                    </li>
                                ))}
                            </ul>
                        </div>

                        <div>
                            <h4 className="font-bold text-xs uppercase tracking-widest mb-3 text-[#1C1C1C]">Follow Us</h4>
                            <div className="flex space-x-3">
                                {[Instagram, Linkedin, Twitter].map((Icon, i) => (
                                    <a key={i} href="#" className="w-8 h-8 rounded-full bg-[#FAFAF7] border border-gray-200 flex items-center justify-center text-[#6B7280] hover:bg-[#C8A153] hover:text-white hover:border-[#C8A153] transition-all">
                                        <Icon size={14} />
                                    </a>
                                ))}
                            </div>
                        </div>
                    </div>
                    <div className="max-w-7xl mx-auto px-6 lg:px-8 mt-6 pt-4 border-t border-gray-100 flex flex-col md:flex-row justify-between items-center text-xs text-[#6B7280]">
