const Button = ({ children, variant = 'primary', className = '', onClick, icon }) => {
    const baseStyle = "inline-flex items-center justify-center font-bold px-6 py-3 rounded-full transition-all duration-300";
    const variants = {
        primary: "bg-[#C8A153] text-white hover:bg-[#b08c46] hover:shadow-lg hover:-translate-y-0.5",
        secondary: "bg-[#1C1C1C] text-white hover:bg-[#333] hover:shadow-lg hover:-translate-y-0.5",
